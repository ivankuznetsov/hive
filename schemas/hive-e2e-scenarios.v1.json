{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ivankuznetsov/hive/blob/main/schemas/hive-e2e-scenarios.v1.json",
  "title": "hive-e2e scenario inventory (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "scenarios"],
  "properties": {
    "schema": { "const": "hive-e2e-scenarios" },
    "schema_version": { "const": 1 },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "tags", "description", "path", "steps_count"],
        "properties": {
          "name": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "path": { "type": "string" },
          "steps_count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
