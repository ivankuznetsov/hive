---
project_name: <%= project_name %>
default_branch: <%= default_branch %>
worktree_root: <%= worktree_root %>
hive_state_path: .hive-state
max_review_passes: 4

# Stage-level agent for the three single-agent stages. (5-review uses
# the per-role agent fields under `review.{ci,triage,fix,browser_test}`
# below.) Defaults are claude for planning (deeper reasoning) and codex
# for development (its edit-mode is more efficient for implementation).
brainstorm:
  agent: <%= planning_agent %>
plan:
  agent: <%= planning_agent %>
execute:
  agent: <%= development_agent %>

# Generous sanity caps for runaway agents, not cost targets. Most
# tasks finish well within them; tighten manually only if you hit a
# cap repeatedly. (The deprecated execute_review key from older
# configs has been dropped — 5-review owns reviewer budgets per
# ADR-014.)
budget_usd:
<% Hive::Commands::Init::Prompts::LIMIT_KEYS.each do |key| -%>
  <%= key %>: <%= budgets[key] %>
<% end -%>

timeout_sec:
<% Hive::Commands::Init::Prompts::LIMIT_KEYS.each do |key| -%>
  <%= key %>: <%= timeouts[key] %>
<% end -%>

# 5-review stage configuration. Each role takes an `agent` (one of the
# names registered in Hive::AgentProfiles — claude, codex, pi by default)
# and an optional `prompt_template` path under templates/.
review:
  ci:
    # Path to the project's CI command. `null` skips the CI-fix phase.
    # Example: "bin/ci" for hive itself, "bin/rails test" for a Rails project.
    command: null
    max_attempts: 3
    agent: claude
    prompt_template: ci_fix_prompt.md.erb
  triage:
    enabled: true
    agent: claude
    # Bias presets:
    #   - courageous (default): action-biased — auto-fix polish, clarity,
    #     mechanical findings; escalate only architecture / auth /
    #     contradictions / low-confidence.
    #   - safetyist: escalation-biased — auto-fix only the truly mechanical
    #     (typos, lint); escalate anything else by default.
    bias: courageous
    # Optional path under <hive-state>/templates/ to override the bias
    # preset's prompt entirely.
    custom_prompt: null
  fix:
    agent: claude
    prompt_template: fix_prompt.md.erb
  browser_test:
    # Set to true for projects that have a browsable surface (Rails apps,
    # web frontends). Hive itself (CLI tool) leaves this disabled.
    enabled: false
    agent: claude
    prompt_template: browser_test_prompt.md.erb
    max_attempts: 2
  max_passes: 4
  # Aggregate wall-clock cap across all phases of one `hive run` on a
  # 5-review folder. 5400s = 90 min.
  max_wall_clock_sec: 5400
  # Hive's recommended reviewer set: claude /ce-code-review + codex
  # /ce-code-review + claude /pr-review-toolkit:review-pr. Each entry's
  # `name` becomes part of the output filename (`reviews/<name>-<pass>.md`).
  # The init prompt's reviewer multiselect controls which entries land
  # here; disabled reviewers are omitted from the array entirely. The
  # deep-merge replaces `review.reviewers` wholesale, so editing this
  # list later replaces it (no per-element merge).
  reviewers:
<% if enabled_reviewers.include?("claude-ce-code-review") -%>
    - name: claude-ce-code-review
      kind: agent
      agent: claude
      skill: ce-code-review
      output_basename: claude-ce-code-review
      prompt_template: reviewer_claude_ce_code_review.md.erb
      budget_usd: 50
      timeout_sec: 600
<% end -%>
<% if enabled_reviewers.include?("codex-ce-code-review") -%>
    - name: codex-ce-code-review
      kind: agent
      agent: codex
      skill: ce-code-review
      output_basename: codex-ce-code-review
      prompt_template: reviewer_codex_ce_code_review.md.erb
      budget_usd: 50
      timeout_sec: 600
<% end -%>
<% if enabled_reviewers.include?("pr-review-toolkit") -%>
    - name: pr-review-toolkit
      kind: agent
      agent: claude
      skill: pr-review-toolkit:review-pr
      output_basename: pr-review-toolkit
      prompt_template: reviewer_pr_review_toolkit.md.erb
      budget_usd: 50
      timeout_sec: 600
<% end -%>
