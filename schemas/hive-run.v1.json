{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:hive:schema:run:v1",
  "title": "hive run output (v1)",
  "description": "Stable success contract emitted by `hive run --json`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "slug",
    "stage",
    "stage_index",
    "folder",
    "state_file",
    "marker",
    "attrs",
    "commit_action",
    "next_action"
  ],
  "properties": {
    "schema": { "const": "hive-run" },
    "schema_version": { "const": 1 },
    "slug": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": ["inbox", "brainstorm", "plan", "execute", "review", "pr", "done"]
    },
    "stage_index": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },
    "folder": { "type": "string" },
    "state_file": { "type": "string" },
    "marker": {
      "type": "string",
      "enum": [
        "none",
        "waiting",
        "complete",
        "agent_working",
        "execute_waiting",
        "execute_complete",
        "execute_stale",
        "review_working",
        "review_waiting",
        "review_ci_stale",
        "review_stale",
        "review_complete",
        "review_error",
        "error"
      ]
    },
    "attrs": {
      "type": "object",
      "additionalProperties": true
    },
    "commit_action": { "type": ["string", "null"] },
    "next_action": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["edit", "mv", "approve", "run", "recover_stale", "no_op"]
        }
      }
    }
  }
}
