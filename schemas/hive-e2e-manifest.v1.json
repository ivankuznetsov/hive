{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ivankuznetsov/hive/blob/main/schemas/hive-e2e-manifest.v1.json",
  "title": "hive-e2e artifact manifest (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "generated_at", "files", "capture_errors"],
  "properties": {
    "schema": { "const": "hive-e2e-manifest" },
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "capture_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "error"],
        "properties": {
          "label": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    }
  }
}
