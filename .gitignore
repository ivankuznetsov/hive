/.bundle/
/vendor/bundle/
/tmp/
*.gem
!/test/e2e/sample-project/vendor/cache/*.gem
.byebug_history
/coverage/
/.qmd/
# Runtime registry of installed projects — machine-specific, not source.
# See config.example.yml for the schema.
/config.yml
# Per-developer Claude Code config and Codex CLI marker. Use the un-slashed
# form too so a symlink at /.claude (e.g. into a private overlay) is ignored.
/.claude
/.claude/
/.codex
# Internal planning artefacts (kept out of public repo). Both un-slashed and
# slashed forms so the patterns match either a directory or a symlink.
/docs/brainstorms
/docs/brainstorms/
/docs/plans
/docs/plans/
/raw/
# Per-skill scratchpad and run artefacts (e.g. .context/compound-engineering/
# ce-code-review/<run-id>/*.json from the /ce-code-review skill). These are
# locally-scoped runtime outputs, not source.
/.context
/.context/
/test/e2e/runs/*
!/test/e2e/runs/.gitkeep
