#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))
$LOAD_PATH.unshift(File.expand_path("../test/e2e/lib", __dir__))

require "json"
require "open3"
require "thor"
require "hive"
require "runner"

# Mirror bin/hive: intercept `--version`/`-v` BEFORE Thor dispatch so the
# default_task `:run_scenarios` doesn't swallow it as a positional pattern.
if ARGV == [ "--version" ] || ARGV == [ "-v" ]
  puts Hive::VERSION
  exit 0
end

module Hive
  module E2E
    # Process exit-code contract for the e2e binary. Mirrors the inner
    # bin/hive routing: success / failure / config so wrapper scripts and
    # CI matrices can branch precisely.
    #
    #   0   = all scenarios passed
    #   1   = one or more scenarios failed
    #   78  = preflight failure (missing tooling, bad config, missing repro)
    module BinaryExit
      SUCCESS = 0
      FAILURE = 1
      CONFIG  = Hive::ExitCodes::CONFIG # 78
    end

    class PreflightError < StandardError; end

    module Preflight
      module_function

      TMUX_INSTALL_HINT = "tmux not found. Install with: `brew install tmux` (macOS), " \
                          "`apt install tmux` (Debian/Ubuntu), or `pacman -S tmux` (Arch).".freeze

      ASCIINEMA_INSTALL_HINT = "asciinema 2.4+ not found. Install with: `pipx install asciinema` " \
                               "(cross-platform), `brew install asciinema` (macOS), or " \
                               "`pacman -S asciinema` (Arch).".freeze

      def require_tmux!
        _out, _err, status = Open3.capture3("tmux", "-V")
        raise PreflightError, TMUX_INSTALL_HINT unless status.success?
      rescue Errno::ENOENT
        raise PreflightError, TMUX_INSTALL_HINT
      end

      def require_asciinema!
        require "asciinema_driver"
        return if AsciinemaDriver.available? && AsciinemaDriver.version &&
                  AsciinemaDriver.version >= AsciinemaDriver::MIN_VERSION

        raise PreflightError, ASCIINEMA_INSTALL_HINT
      end
    end

    class Binary < Thor
      class_option :json, type: :boolean, default: false,
                          desc: "Emit structured JSON output where applicable"

      default_task :run_scenarios

      desc "run [PATTERN]", "Run e2e scenarios"
      option :filter, type: :string, desc: "run scenarios with the given tag"
      option :keep_artifacts, type: :boolean, default: false, desc: "keep run-home directories after passing scenarios"
      def run_scenarios(pattern = nil)
        Preflight.require_tmux!
        report = Runner.new.run_all(pattern: pattern, tag: options[:filter], keep_artifacts: options[:keep_artifacts])
        if options[:json]
          puts JSON.pretty_generate(report)
        end
        summary = report.fetch("summary")
        failed = summary.fetch("failed") + summary.fetch("setup_failed", 0)
        exit(failed.zero? ? BinaryExit::SUCCESS : BinaryExit::FAILURE)
      rescue PreflightError => e
        warn "hive-e2e: #{e.message}"
        exit BinaryExit::CONFIG
      end
      map "run" => :run_scenarios

      desc "version", "Print hive gem version"
      def version
        puts Hive::VERSION
      end

      desc "list", "List available e2e scenarios"
      def list
        scenarios = Runner.new.select_scenarios
        if options[:json]
          payload = {
            "schema" => "hive-e2e-scenarios",
            "schema_version" => 1,
            "scenarios" => scenarios.map { |scenario| scenario_summary(scenario) }
          }
          puts JSON.pretty_generate(payload)
        else
          scenarios.each do |scenario|
            tags = scenario.tags.empty? ? "" : " [#{scenario.tags.join(', ')}]"
            puts "#{scenario.name}#{tags}"
          end
        end
      end

      desc "replay RUN_ID SCENARIO", "Replay a stored scenario repro script"
      def replay(run_id, scenario)
        script = File.join(Paths.runs_dir, run_id, "scenarios", scenario, "repro.sh")
        unless File.exist?(script)
          warn "hive-e2e: Run ##{run_id} scenario #{scenario} has no repro.sh; the run may have completed successfully (#{script})"
          exit BinaryExit::CONFIG
        end

        exec script
      end

      desc "clean", "Remove old e2e run artifacts"
      option :retain_days, type: :numeric, default: ENV.fetch("RUNS_RETAIN_DAYS", 7).to_i
      option :retain_failed_days, type: :numeric, default: ENV.fetch("RUNS_RETAIN_FAILED_DAYS", 14).to_i
      def clean
        result = Sandbox.cleanup_runs(retain_days: options[:retain_days], retain_failed_days: options[:retain_failed_days])
        deleted = result.fetch("deleted")
        kept = result.fetch("kept")
        if options[:json]
          puts JSON.pretty_generate(
            "schema" => "hive-e2e-clean",
            "schema_version" => 1,
            "deleted" => deleted,
            "kept" => kept
          )
        else
          puts "deleted: #{deleted}, kept: #{kept}"
        end
      end

      private

      def scenario_summary(scenario)
        {
          "name" => scenario.name,
          "tags" => scenario.tags,
          "description" => scenario.description,
          "path" => scenario.path,
          "steps_count" => scenario.steps.size
        }
      end
    end
  end
end

begin
  Hive::E2E::Binary.start(ARGV)
rescue Hive::E2E::PreflightError => e
  warn "hive-e2e: #{e.message}"
  exit Hive::E2E::BinaryExit::CONFIG
rescue StandardError => e
  warn "hive-e2e: #{e.message}"
  exit Hive::E2E::BinaryExit::FAILURE
end
